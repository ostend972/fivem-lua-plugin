{
  "description": "FiveM Lua plugin hooks for automatic code quality enforcement",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/lua-quality-check.sh"
          }
        ]
      }
    ]
  }
}
